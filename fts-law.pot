#: page-pt-pma.php:399
msgid "Week 3–5"
msgstr ""

#: page-pt-pma.php:401
msgid "Corporate bank account opening, capital injection, sector licence applications, and BKPM/OSS investment plan registration."
msgstr ""

#: page-pt-pma.php:407
